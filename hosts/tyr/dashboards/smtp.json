{
  "uid": "smtp-hermes",
  "title": "Hermes SMTP",
  "tags": ["mail", "smtp", "postfix", "hermes"],
  "timezone": "browser",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Postfix exporter up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "up{job=\"postfix\"}", "legendFormat": "{{instance}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "justifyMode": "center", "textMode": "auto" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Dovecot exporter up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "up{job=\"dovecot\"}", "legendFormat": "{{instance}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "justifyMode": "center", "textMode": "auto" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Queued mail",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(postfix_showq_queue_depth{job=\"postfix\"})", "legendFormat": "queued" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "area", "justifyMode": "center", "textMode": "auto" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "SASL auth failures / hour",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(increase(postfix_smtpd_sasl_authentication_failures_total{job=\"postfix\"}[1h]))", "legendFormat": "failures" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 20 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "area", "justifyMode": "center", "textMode": "auto" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Queue depth by queue",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "refId": "A", "expr": "postfix_showq_queue_depth{job=\"postfix\"}", "legendFormat": "{{queue}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 20, "showPoints": "never", "spanNulls": false }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "none" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "SMTP throughput / failures",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(postfix_smtpd_connects_total{job=\"postfix\"}[5m]))", "legendFormat": "smtpd connects/s" },
        { "refId": "B", "expr": "sum(rate(postfix_cleanup_messages_rejected_total{job=\"postfix\"}[5m]))", "legendFormat": "rejected/s" },
        { "refId": "C", "expr": "sum(rate(postfix_smtp_deferred_messages_total{job=\"postfix\"}[5m]))", "legendFormat": "deferred/s" },
        { "refId": "D", "expr": "sum(rate(postfix_virtual_delivered_total{job=\"postfix\"}[5m]))", "legendFormat": "local delivered/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": false }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "none" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Auth failures",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(postfix_smtpd_sasl_authentication_failures_total{job=\"postfix\"}[5m]))", "legendFormat": "postfix sasl failures/s" },
        { "refId": "B", "expr": "sum(rate(dovecot_user_auth_failures{job=\"dovecot\"}[5m]))", "legendFormat": "dovecot auth failures/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": false }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "none" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Dovecot logins by account",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "refId": "A", "expr": "sum by (user) (rate(dovecot_user_num_logins{job=\"dovecot\"}[5m]))", "legendFormat": "{{user}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": false }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "none" } }
    }
  ]
}
