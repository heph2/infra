{
  "enabled": true,
  "network": {
    "allowNetwork": false,
    "allowLocalBinding": true,
    "allowAllUnixSockets": false,
    "allowUnixSockets": [],
    "allowedDomains": [
      "api.github.com",
      "github.com",
      "*.github.com",
      "raw.githubusercontent.com",
      "npmjs.org",
      "*.npmjs.org",
      "registry.npmjs.org",
      "pi.dev",
      "*.pi.dev"
    ],
    "deniedDomains": []
  },
  "filesystem": {
    "denyRead": [
      "/home",
      "/Users"
    ],
    "allowRead": [
      ".",
      "~/.gitconfig",
      "~/.config/git/config",
      "/dev/null"
    ],
    "allowWrite": [
      ".",
      "/tmp",
      "/dev/null"
    ],
    "denyWrite": [
      "**/.env",
      "**/.env.*",
      "**/*.pem",
      "**/*.key",
      ".pi/sandbox.json",
      "~/.pi/agent/sandbox.json"
    ]
  }
}
